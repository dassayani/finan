generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String         @unique
  emailVerified DateTime?      @map("email_verified")
  image         String?
  password      String?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  accounts      Account[]
  sessions      Session[]
  transactions  Transaction[]
  subscriptions Subscription[]
  investments   Investment[]
  salaries      Salary[]
  bankFees      BankFee[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Salary {
  id         String       @id @default(cuid())
  userId     String       @map("user_id")
  month      Int
  year       Int
  baseAmount Decimal      @db.Decimal(12, 2) @map("base_amount")
  netAmount  Decimal      @db.Decimal(12, 2) @map("net_amount")
  payDay     Int?         @map("pay_day")
  notes      String?
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  items      SalaryItem[]

  @@unique([userId, month, year])
  @@map("salaries")
}

model SalaryItem {
  id        String         @id @default(cuid())
  salaryId  String         @map("salary_id")
  name      String
  amount    Decimal        @db.Decimal(12, 2)
  type      SalaryItemType
  order     Int            @default(0)
  salary    Salary         @relation(fields: [salaryId], references: [id], onDelete: Cascade)

  @@map("salary_items")
}

enum SalaryItemType {
  PROVENTO
  DESCONTO
}

model Transaction {
  id               String          @id @default(cuid())
  description      String
  amount           Decimal         @db.Decimal(12, 2)
  type             TransactionType
  expenseType      ExpenseType?    @map("expense_type")
  category         CategoryKey?
  bank             BankKey?
  date             DateTime
  notes            String?
  isPaid           Boolean         @default(false) @map("is_paid")
  installments     Int?
  installmentIndex Int?            @map("installment_index")
  groupId          String?         @map("group_id")
  userId           String          @map("user_id")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum ExpenseType {
  FIXED
  VARIABLE
  BANK_BILL
}

enum CategoryKey {
  casa
  alim
  imprev
  transp
  saude
  pet
  assin
  lazer
  compras
  trab
  viagem
  reserva
  tarifas
  reemb
}

enum BankKey {
  caixa
  bb
  itau
  nubank
  picpay
  inter
  mp
}

model Subscription {
  id        String               @id @default(cuid())
  userId    String               @map("user_id")
  name      String
  brand     String               @default("#6366f1")
  icon      String               @default("repeat")
  total     Decimal              @db.Decimal(12, 2)
  account   String?
  createdAt DateTime             @default(now()) @map("created_at")
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  members   SubscriptionMember[]

  @@map("subscriptions")
}

model SubscriptionMember {
  id             String       @id @default(cuid())
  subscriptionId String       @map("subscription_id")
  name           String
  share          Decimal      @db.Decimal(12, 2)
  isOwner        Boolean      @default(false) @map("is_owner")
  paidAt         DateTime?    @map("paid_at")
  month          Int
  year           Int
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("subscription_members")
}

// Bank fees configured once, applied automatically each month
model BankFee {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  bank       BankKey
  name       String
  amount     Decimal  @db.Decimal(12, 2)
  billingDay Int      @default(1) @map("billing_day")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bank_fees")
}

model Investment {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  name        String
  type        String
  institution BankKey?
  value       Decimal   @db.Decimal(12, 2)
  returnRate  Decimal?  @db.Decimal(6, 4) @map("return_rate")
  monthlyAdd  Decimal?  @db.Decimal(12, 2) @map("monthly_add")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("investments")
}
