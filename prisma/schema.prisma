generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String         @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  accounts      Account[]
  sessions      Session[]
  transactions  Transaction[]
  subscriptions Subscription[]
  investments   Investment[]
  salaries      Salary[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Salary (holerite CLT)
model Salary {
  id          String        @id @default(cuid())
  userId      String
  month       Int
  year        Int
  baseAmount  Decimal       @db.Decimal(12, 2)
  netAmount   Decimal       @db.Decimal(12, 2)
  payDay      Int?
  notes       String?
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       SalaryItem[]

  @@unique([userId, month, year])
}

model SalaryItem {
  id        String          @id @default(cuid())
  salaryId  String
  name      String
  amount    Decimal         @db.Decimal(12, 2)
  type      SalaryItemType
  salary    Salary          @relation(fields: [salaryId], references: [id], onDelete: Cascade)
}

enum SalaryItemType {
  PROVENTO
  DESCONTO
}

// Main transaction (income or expense)
model Transaction {
  id               String          @id @default(cuid())
  description      String
  amount           Decimal         @db.Decimal(12, 2)
  type             TransactionType
  expenseType      ExpenseType?
  category         CategoryKey?
  bank             BankKey?
  date             DateTime
  notes            String?
  isPaid           Boolean         @default(false)
  installments     Int?
  installmentIndex Int?
  groupId          String?         // links installments of the same purchase
  userId           String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum ExpenseType {
  FIXED
  VARIABLE
  BANK_BILL
}

enum CategoryKey {
  casa
  alim
  imprev
  transp
  saude
  pet
  assin
  lazer
  compras
  trab
  viagem
  reserva
  tarifas
  reemb
}

enum BankKey {
  caixa
  bb
  itau
  nubank
  picpay
  inter
  mp
}

// Subscriptions shared with other people
model Subscription {
  id        String               @id @default(cuid())
  userId    String
  name      String
  brand     String               @default("#6366f1")
  icon      String               @default("repeat")
  total     Decimal              @db.Decimal(12, 2)
  account   String?
  createdAt DateTime             @default(now())
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  members   SubscriptionMember[]
}

model SubscriptionMember {
  id             String       @id @default(cuid())
  subscriptionId String
  name           String
  share          Decimal      @db.Decimal(12, 2)
  isOwner        Boolean      @default(false)
  paidAt         DateTime?
  month          Int
  year           Int
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

// Investments
model Investment {
  id           String     @id @default(cuid())
  userId       String
  name         String
  type         String
  institution  BankKey?
  value        Decimal    @db.Decimal(12, 2)
  returnRate   Decimal?   @db.Decimal(6, 4)
  monthlyAdd   Decimal?   @db.Decimal(12, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}
