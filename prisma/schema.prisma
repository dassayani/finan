generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String         @unique
  emailVerified DateTime?      @map("email_verified")
  image         String?
  password      String?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  accounts      Account[]
  sessions      Session[]
  transactions  Transaction[]
  subscriptions Subscription[]
  investments   Investment[]
  salaries      Salary[]
  bankFees      BankFee[]
  bankBalances  BankBalance[]
  customBanks   CustomBank[]
  bankEntries   BankEntry[]
  bankConfigs   BankConfig[]
  loans         Loan[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Salary {
  id                 String      @id @default(cuid())
  userId             String      @map("user_id")
  month              Int
  year               Int
  baseAmount         Decimal     @db.Decimal(12, 2) @map("base_amount")
  netAmount          Decimal     @db.Decimal(12, 2) @map("net_amount")
  payDay             Int?        @map("pay_day")
  notes              String?
  salaryBank           BankKey?    @map("salary_bank")
  salaryCustomBankId   String?     @map("salary_custom_bank_id")
  salaryBankSinceMonth Int?        @map("salary_bank_since_month")
  salaryBankSinceYear  Int?        @map("salary_bank_since_year")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  salaryCustomBank   CustomBank? @relation("SalarySalaryBank", fields: [salaryCustomBankId], references: [id], onDelete: SetNull)
  items              SalaryItem[]

  @@unique([userId, month, year])
  @@map("salaries")
}

model SalaryItem {
  id        String         @id @default(cuid())
  salaryId  String         @map("salary_id")
  name      String
  amount    Decimal        @db.Decimal(12, 2)
  type      SalaryItemType
  order     Int            @default(0)
  salary    Salary         @relation(fields: [salaryId], references: [id], onDelete: Cascade)

  @@map("salary_items")
}

enum SalaryItemType {
  PROVENTO
  DESCONTO
}

model Transaction {
  id               String          @id @default(cuid())
  description      String
  amount           Decimal         @db.Decimal(12, 2)
  type             TransactionType
  expenseType      ExpenseType?    @map("expense_type")
  category         CategoryKey?
  bank             BankKey?
  date             DateTime
  notes            String?
  isPaid           Boolean         @default(false) @map("is_paid")
  installments     Int?
  installmentIndex Int?            @map("installment_index")
  groupId          String?         @map("group_id")
  userId           String          @map("user_id")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum ExpenseType {
  FIXED
  VARIABLE
  BANK_BILL
}

enum CategoryKey {
  casa
  alim
  imprev
  transp
  saude
  pet
  assin
  lazer
  compras
  trab
  viagem
  reserva
  tarifas
  reemb
  salario
  freelance
  aluguel_rec
  dividendos
  presente
  outros_rec
}

enum BankKey {
  caixa
  bb
  itau
  nubank
  picpay
  inter
  mp
}

model Subscription {
  id           String               @id @default(cuid())
  userId       String               @map("user_id")
  name         String
  brand        String               @default("#6366f1")
  icon         String               @default("repeat")
  total        Decimal              @db.Decimal(12, 2)
  account      String?
  period       String               @default("mensal")
  startDate    DateTime?            @map("start_date")
  bank         BankKey?
  customBankId String?              @map("custom_bank_id")
  createdAt    DateTime             @default(now()) @map("created_at")
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  customBank   CustomBank?          @relation(fields: [customBankId], references: [id], onDelete: SetNull)
  members      SubscriptionMember[]

  @@map("subscriptions")
}

model SubscriptionMember {
  id             String                @id @default(cuid())
  subscriptionId String                @map("subscription_id")
  name           String
  share          Decimal               @db.Decimal(12, 2)
  isOwner        Boolean               @default(false) @map("is_owner")
  subscription   Subscription          @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  payments       SubscriptionPayment[]

  @@map("subscription_members")
}

model SubscriptionPayment {
  id       String             @id @default(cuid())
  memberId String             @map("member_id")
  month    Int
  year     Int
  paidAt   DateTime           @default(now()) @map("paid_at")
  member   SubscriptionMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, month, year])
  @@map("subscription_payments")
}

// Bank fees configured once, applied automatically each month
model BankFee {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  bank       BankKey
  name       String
  amount     Decimal  @db.Decimal(12, 2)
  billingDay Int      @default(1) @map("billing_day")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bank_fees")
}

model Investment {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  name        String
  type        String
  institution BankKey?
  value       Decimal   @db.Decimal(12, 2)
  returnRate  Decimal?  @db.Decimal(6, 4) @map("return_rate")
  monthlyAdd  Decimal?  @db.Decimal(12, 2) @map("monthly_add")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("investments")
}

model CustomBank {
  id          String              @id @default(cuid())
  userId      String              @map("user_id")
  name        String
  short       String
  color       String              @default("#6B7280")
  agency      String?
  account     String?
  accountType String?             @map("account_type")
  cutoffDay   Int?                @map("cutoff_day")
  dueDay      Int?                @map("due_day")
  createdAt   DateTime            @default(now()) @map("created_at")
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  fees          CustomBankFee[]
  balances      CustomBankBalance[]
  entries       BankEntry[]
  salaries      Salary[]        @relation("SalarySalaryBank")
  subscriptions Subscription[]
  loans         Loan[]

  @@map("custom_banks")
}

model BankConfig {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  bank        BankKey
  agency      String?
  account     String?
  accountType String?  @map("account_type")
  cutoffDay   Int?     @map("cutoff_day")
  dueDay      Int?     @map("due_day")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, bank])
  @@map("bank_configs")
}

model CustomBankBalance {
  id           String     @id @default(cuid())
  customBankId String     @map("custom_bank_id")
  month        Int
  year         Int
  balance      Decimal    @db.Decimal(12, 2)
  updatedAt    DateTime   @updatedAt @map("updated_at")
  customBank   CustomBank @relation(fields: [customBankId], references: [id], onDelete: Cascade)

  @@unique([customBankId, month, year])
  @@map("custom_bank_balances")
}

model CustomBankFee {
  id           String     @id @default(cuid())
  customBankId String     @map("custom_bank_id")
  name         String
  amount       Decimal    @db.Decimal(12, 2)
  billingDay   Int        @default(1)
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now()) @map("created_at")
  customBank   CustomBank @relation(fields: [customBankId], references: [id], onDelete: Cascade)

  @@map("custom_bank_fees")
}

model BankEntry {
  id           String          @id @default(cuid())
  userId       String          @map("user_id")
  bank         BankKey?
  customBankId String?         @map("custom_bank_id")
  month        Int
  year         Int
  description  String
  amount       Decimal         @db.Decimal(12, 2)
  type         TransactionType
  isPaid       Boolean         @default(false) @map("is_paid")
  groupId      String?         @map("group_id")
  installments Int?
  category     CategoryKey?
  createdAt    DateTime        @default(now()) @map("created_at")
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  customBank   CustomBank?     @relation(fields: [customBankId], references: [id], onDelete: Cascade)

  @@map("bank_entries")
}

model BankBalance {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  bank      BankKey
  month     Int
  year      Int
  balance   Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, bank, month, year])
  @@map("bank_balances")
}

model Loan {
  id           String        @id @default(cuid())
  userId       String        @map("user_id")
  name         String
  type         String        @default("pessoal")
  creditor     String
  owner        String
  totalAmount  Decimal       @db.Decimal(12, 2) @map("total_amount")
  installment  Decimal       @db.Decimal(12, 2)
  installments   Int
  excludedMonths Json          @default("[]") @map("excluded_months")
  startDate      DateTime      @map("start_date")
  bank           BankKey?
  customBankId String?       @map("custom_bank_id")
  notes        String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  customBank   CustomBank?   @relation(fields: [customBankId], references: [id], onDelete: SetNull)
  payments     LoanPayment[]

  @@map("loans")
}

model LoanPayment {
  id     String   @id @default(cuid())
  loanId String   @map("loan_id")
  month  Int
  year   Int
  paidAt DateTime @default(now()) @map("paid_at")
  loan   Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@unique([loanId, month, year])
  @@map("loan_payments")
}
